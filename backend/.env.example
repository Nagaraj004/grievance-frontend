# Database — update with your PostgreSQL credentials
DATABASE_URL=postgresql://postgres:password@localhost:5432/grievance_db
DATABASE_SCHEMA=Grievance

# JWT — CHANGE THIS IN PRODUCTION
SECRET_KEY=your-super-secret-jwt-key-change-this-in-production-min-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# App
APP_NAME=Tamil Nadu Grievance Portal
APP_VERSION=1.0.0
DEBUG=true
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000